DEVICE_ID=raspi-anchor-01
EVIDENCE_DIR=./output
EDGE_VERSION=0.1.0
BUTTON_COUNT=2
API_BASE_URL=http://localhost:7071/api
DEVICE_API_KEY=local-demo-device-key
ADMIN_API_KEY=local-demo-admin-key
ALLOW_LOCAL_DEVICE_HTTP=true
VERIFY_BASE_URL=http://localhost:7071
CLOUD_SYNC_ENABLED=false
BUTTON_GPIO=17
LED_GPIO=27
BUTTON_DEBOUNCE_MS=200
GROVE_SERIAL_PORT=/dev/serial/by-id/replace-with-arduino-device
GROVE_BAUD_RATE=115200
GROVE_STARTUP_DELAY_SECONDS=2
CAMERA_COMMAND=rpicam-still
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_TIMEOUT_MS=1000
AUDIO_DEVICE=plughw:1,0
AUDIO_DURATION_SECONDS=8
IOT_HUB_DEVICE_CONNECTION_STRING=
IOT_HEARTBEAT_SECONDS=60
ALLOWED_DEVICE_IDS=raspi-anchor-01
LOCAL_DATA_DIR=cloud-functions/.local-data
TIME_LIMIT_SECONDS=30
GRACE_SECONDS=15
STUB_SIGNING_SECRET=replace-with-local-development-secret
SIGNATURE_KEY_ID=local-stub-v1
PUBLIC_WEB_BASE_URL=http://localhost:7071
USE_AZURE_STORAGE=false
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=replace-with-storage-account
AZURE_BLOB_CONTAINER_EVIDENCE=reality-evidence
AZURE_BLOB_CONTAINER_PROOFS=reality-proofs
AZURE_TABLE_SESSIONS=RealitySessions
AZURE_TABLE_EVIDENCE=RealityEvidence
AZURE_TABLE_PROOFS=RealityProofs
AZURE_TABLE_DEVICES=RealityDevices
AZURE_TABLE_AUDIT_LOGS=RealityAuditLogs
AZURE_STORAGE_SAS_TTL_SECONDS=300
USE_AZURE_KEY_VAULT=false
AZURE_KEY_VAULT_URL=https://replace-with-vault.vault.azure.net
AZURE_KEY_VAULT_KEY_NAME=reality-proof-signing
AZURE_KEY_VAULT_KEY_VERSION=
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
USE_IOT_HUB=false
IOT_HUB_SERVICE_CONNECTION_STRING=
IOT_HUB_EVENT_CONNECTION=
IOT_HUB_EVENT_HUB_NAME=messages/events
IOT_HUB_CONSUMER_GROUP=$Default
